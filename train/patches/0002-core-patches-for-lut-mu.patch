+# Patch added: support brevitas QuantTensor wrappers and plain torch.Tensor
+def unwrap_tensor(x: Any) -> torch.Tensor:
+    """Return a plain torch.Tensor from x.
+
+    Supports:
+    - plain torch.Tensor (returned unchanged)
+    - brevitas QuantTensor (has attribute `tensor`)
+    - objects exposing `value` or array-like (falls back to torch.as_tensor)
+    """
+    if isinstance(x, torch.Tensor):
+        return x
+    if hasattr(x, "tensor"):
+        return getattr(x, "tensor")
+    if hasattr(x, "value"):
+        return getattr(x, "value")
+    return torch.as_tensor(x)
+
 
 def create_selection_matrix(
     C: int = 1, K: int = 16, dtype=torch.float16
@@ -138,6 +167,59 @@ def apply_decision_tree_torch(
     return mapping
 
 
+# Patch added: self defined for any number of prototype (K)
+def create_selection_matrix_any_K(
+    C: int = 1, K: int = 16, dtype=torch.float16
+) -> torch.Tensor:
+    # 15 is the number of split threshold for 16 prototypes
+    depth = int(math.log2(K))
+    selection_matrix = torch.zeros((C * (K - 1), C * depth), dtype=dtype)
+    based_selection_matrix = torch.zeros((K - 1, depth), dtype=dtype)
+    for i in range(K - 1):
+        if i == 0:
+            based_selection_matrix[0, 0] = 1
+        else:
+            based_selection_matrix[i, int(np.log2(i + 1))] = 1
+    for c in range(C):
+        selection_matrix[
+            c * (K - 1) : (c + 1) * (K - 1), c * depth : (c + 1) * depth
+        ] = based_selection_matrix
+    return selection_matrix
+
+
+def dfs_create(a_bit_matrix, now_depth, to_depth, k, idx):
+
+    if now_depth == to_depth:
+        return a_bit_matrix
+    
+    # same dim=1 order as halutmat
+    nx_idx = (k & (2**(to_depth - now_depth - 1)) > 0) + 2*idx + 1
+    a_bit_matrix[idx] = 1. if (k & (2**(to_depth - now_depth - 1))) else -1.
+    # nx_idx = (k & (2**now_depth) > 0) + 2*idx + 1
+    # a_bit_matrix[idx] = 1. if (k & (2**now_depth)) else -1.
+    
+    return dfs_create(a_bit_matrix, now_depth + 1, to_depth, k, nx_idx)
+
+# self defined for any number of prototype (K)
+def create_bit_matrix_any_K(C: int = 1, K: int = 16, dtype=torch.float16) -> torch.Tensor:
+    # example when using C = 1
+    # fmt: off
+    depth = int(math.log2(K))
+    bit_matrix_numpy = np.zeros((K, K - 1))
+    for k in range(K):
+        a_bit_matrix = np.zeros(K-1)
+        bit_matrix_numpy[k] = dfs_create(a_bit_matrix, 0, depth, k, 0)
+
+    # fmt: on
+    bit_matrix_base = torch.from_numpy(bit_matrix_numpy).to(dtype)
+    bit_matrix = torch.ones((C * K, C * (K - 1)), dtype=dtype)
+    for c in range(C):
+        bit_matrix[
+            c * K : (c + 1) * K,
+            c * (K - 1) : (c + 1) * (K - 1),
+        ] = bit_matrix_base
+    return bit_matrix
+
