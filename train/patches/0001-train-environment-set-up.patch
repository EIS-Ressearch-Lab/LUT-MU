From 1b9f0e31d4df5035b8280e47714fe2e96808eab3 Mon Sep 17 00:00:00 2001
From: PeiGiZhu <peigizhu@outlook.com>
Date: Tue, 9 Jun 2026 22:39:09 +0000
Subject: [PATCH 1/2] train environment set up

---
 train/environment_cuda11.yml | 61 ++++++++++++++++++++++++++++++++++++
 train/environment_cuda12.yml | 61 ++++++++++++++++++++++++++++++++++++
 2 files changed, 122 insertions(+)
 create mode 100644 train/environment_cuda11.yml
 create mode 100644 train/environment_cuda12.yml

diff --git a/train/environment_cuda11.yml b/train/environment_cuda11.yml
new file mode 100644
index 0000000..c9405c2
--- /dev/null
+++ b/train/environment_cuda11.yml
@@ -0,0 +1,61 @@
+name: halutmatmul
+channels:
+  - pytorch
+  - nvidia
+  - conda-forge
+  - defaults
+dependencies:
+  - python=3.9
+  # IDE deps
+  - black
+  - pylint=2.17
+  - pytest
+  - pre-commit
+  - pytest-xdist
+  # algo dependencies
+  - numpy=1.21.2
+  - numba
+  - joblib
+  - scipy
+  - scikit-learn=1.1
+  - torchvision
+  # PyTorch and CUDA for NVIDIA H200 (use CUDA 12.1-compatible build)
+  - pytorch=2.4
+  - torchinfo
+  # kws
+  - torchaudio
+  - pysoundfile
+  # gpu stuff
+  - pytorch-cuda=11.7
+  - pip
+  # analysis
+  - pandas
+  - seaborn
+  - matplotlib
+  # for CI
+  - mypy>=1.4.1
+  # kmeans
+  - faiss-cpu=1.7.3 # https://github.com/facebookresearch/faiss/issues/2890
+  # ci
+  - pytest-split
+  - pip:
+      - tensorboard
+      - cupy_cuda11x
+      - pytorch-nemo
+      - timm==0.5.4
+      - ray
+      - cocotb # needed for mypy
+      - brevitas==0.12.1
+      # repair "undefined symbol: iJIT_NotifyEvent"
+      - mkl==2024.0.0
+
+  # Notes:
+  # - If conda cannot find `intel-oneapi-vtune` on the `intel` channel for your
+  #   platform, try installing Intel VTune / oneAPI using Intel's installer or
+  #   the distribution packages for your OS. The missing symbol `iJIT_NotifyEvent`
+  #   comes from Intel's JIT/profiling library (libiJIT) which VTune provides.
+  # - As a fallback workaround you can compile a small shim that provides stub
+  #   implementations of the iJIT symbols and preload it via LD_PRELOAD or add
+  #   an activation script to the conda env that sets LD_PRELOAD. Example shim
+  #   (C) and quick test were used during debugging; this is safe if you don't
+  #   need VTune profiling features.
\ No newline at end of file
diff --git a/train/environment_cuda12.yml b/train/environment_cuda12.yml
